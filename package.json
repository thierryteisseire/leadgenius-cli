{
  "name": "leadgenius-cli",
  "version": "2.0.10",
  "description": "LeadGenius Pro CLI — B2B lead management, enrichment, scoring, and automation",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": {
    "lgp": "dist/cli/index.js"
  },
  "type": "module",
  "files": [
    "dist/cli/**/*",
    "dist/core/**/*",
    "dist/extension/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "npm run build:cli && npm run build:extension",
    "build:cli": "tsc",
    "build:extension": "esbuild src/extension/popup.ts src/extension/options.ts --bundle --outdir=dist/extension --format=esm --target=chrome100 && cp src/extension/manifest.json src/extension/*.html dist/extension/",
    "build:binary": "esbuild src/cli/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle/cli.cjs && pkg dist/bundle/cli.cjs --out-path dist/bin --targets node18-macos-x64,node18-macos-arm64,node18-win-x64,node18-linux-x64",
    "package": "npm run build:binary",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "leadgenius",
    "cli",
    "b2b",
    "leads",
    "enrichment",
    "scoring",
    "automation",
    "sales",
    "crm",
    "chrome-extension"
  ],
  "author": "Thierry Teisseire",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/leadgenius/cli.git"
  },
  "homepage": "https://last.leadgenius.app",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.266",
    "@types/node": "^20.12.7",
    "esbuild": "^0.20.2",
    "pkg": "^5.8.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist/bin"
  }
}
